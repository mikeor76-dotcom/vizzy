[Unit]
Description=Vizzy EC11 rotary encoder input daemon
Documentation=https://github.com/mikeor76-dotcom/vizzy
# the daemon POSTs to the app server, but it must survive the app restarting,
# so this is a Wants (not a Requires) and it retries on its own
Wants=vizzy.service
After=vizzy.service network.target

[Service]
Type=simple
User=pi
Group=pi
# GPIO character-device access on the Pi 5 comes from the gpio group
SupplementaryGroups=gpio
# gpiozero uses the lgpio backend on the Pi 5, and lgpio writes hidden
# .lgd-nfy* notification files (that's how it delivers edge callbacks) into
# its working directory. systemd defaults WorkingDirectory to / — which a
# non-root user can't write to — so edge detection failed with status=1 even
# though the pins themselves were fine. Give it somewhere writable. LG_WD is
# lgpio's own override and is set as well, belt-and-braces.
WorkingDirectory=/tmp
Environment=LG_WD=/tmp
EnvironmentFile=-/opt/vizzy/state/vizzy.env
# The daemon lives OUTSIDE the release payload on purpose: install.sh only
# copies dist/scripts/package.json/version.json/README.md into current/, and an
# OTA update replaces current/ wholesale — so anything under current/deploy/
# would vanish (it never existed: this unit used to point there and the service
# crash-looped with "No such file"). encoder-setup.sh installs it here.
ExecStart=/usr/bin/python3 /usr/local/lib/vizzy/vizzy-encoder.py
Restart=always
RestartSec=3
# unbuffered so journalctl shows every turn of the knob live
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
